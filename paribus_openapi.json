                    "file": {
                        "type": "string",
                        "format": "binary",
                        "title": "File",
                        "description": "CSV file containing hospital data to bulk process. Must include headers: name, address. Optional header: phone. Maximum 20 rows.",
                        "example": "name,address,phone\nGeneral Hospital,123 Main St,555-1111\nCity Care,456 Side St,"
