{
	"info": {
		"_postman_id": "bfd6e35c-897f-4428-b80c-a99f36f98f6d",
		"name": "Paribus Hospital Bulk Processing System",
		"description": "Postman Collection for testing both local and live deployed instances of the Paribus Bulk Processing API.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "General",
			"item": [
				{
					"name": "1. Root Greeting",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								""
							]
						},
						"description": "Returns the API greeting message to verify service connectivity."
					},
					"response": []
				},
				{
					"name": "2. Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Verify container health status."
					},
					"response": []
				}
			]
		},
		{
			"name": "Bulk Operations",
			"item": [
				{
					"name": "3. Validate CSV (within 20 rows)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"description": "CSV file (Select test.csv, test_single.csv, or test_15.csv locally)",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/hospitals/bulk/validate",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"hospitals",
								"bulk",
								"validate"
							]
						},
						"description": "Validate CSV syntax, headers, and row count limit without making calls to the upstream directory service."
					},
					"response": []
				},
				{
					"name": "4. Bulk Ingest CSV",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.batch_id) {",
									"    pm.environment.set(\"batch_id\", jsonData.batch_id);",
									"    console.log(\"Saved batch_id: \" + jsonData.batch_id);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"description": "CSV file to bulk process.",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/hospitals/bulk",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"hospitals",
								"bulk"
							]
						},
						"description": "Upload a CSV file containing hospital data to ingest, generate a unique batch ID, asynchronously call the upstream API, and activate the batch if all rows succeed. Saves the generated batch ID to the environment variable dynamic namespace."
					},
					"response": []
				},
				{
					"name": "5. Get Batch Ingestion Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/hospitals/bulk/{{batch_id}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"hospitals",
								"bulk",
								"{{batch_id}}"
							]
						},
						"description": "Retrieve execution status, statistics, activation state, and detailed row outcomes for the given batch ID."
					},
					"response": []
				},
				{
					"name": "6. Resume Failed Ingestion In-place",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/hospitals/bulk/{{batch_id}}/resume",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"hospitals",
								"bulk",
								"{{batch_id}}",
								"resume"
							]
						},
						"description": "Trigger processing recovery for a failed/partial batch. Will only retry failed rows and activate the batch upstream once all succeed."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		}
	]
}
